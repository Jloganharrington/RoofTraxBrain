# RoofTrax Brain — environment
# Copy to .env and fill in. Never commit .env.

# Postgres connection (the Brain owns its own database)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rooftrax_brain

# HTTP
PORT=4000

# VisualCrossing (weather engine, B4). Deterministic retrieval only — no LLM.
VISUALCROSSING_API_KEY=

# Object storage base for evidence photos (read-only to the Brain).
# The Brain fetches photo bytes from here to re-hash and render. Set at deploy.
OBJECT_STORAGE_BASE_URL=
