{
  "name": "rooftrax-brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RoofTrax Pro Brain — standalone tenant- and state-aware service that turns a submitted forensic inspection into a claim-ready BEI proof package.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/config/seed.ts",
    "sample": "tsx scripts/build-sample.ts",
    "verify:noaa": "tsx scripts/verify-noaa.ts",
    "noaa": "tsx scripts/noaa-ingest.ts",
    "test": "tsx --test src/**/*.test.ts",
    "verify:b6": "tsx scripts/verify-b6.ts"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@google/genai",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
